# Copy this file to .env.local and fill in your private values.
# Do not commit .env.local.

# Crypto Wizards API
CRYPTO_WIZARDS_BASE_URL=https://api.cryptowizards.net
CRYPTO_WIZARDS_API_KEY=
# Comma-separated endpoint specs: name=/path,name2=https://host/path
CRYPTO_WIZARDS_ENDPOINTS=prescanned=/v1beta/prescanned?priority=Sharpe&strategy=Spread

# Optional public dYdX mainnet indexer override (if DNS/IP fails or endpoint changes).
# If unset, defaults to https://indexer.dydx.trade.
QPA_INDEXER_BASE=https://indexer.dydx.trade
# Optional canonical acceptance report override for readiness / paper gating.
# Example: work/reviewed_gate_corrected_cycle3_2026_06_21/reviewed_gate_acceptance_report.csv
QPA_ACCEPTANCE_REPORT_PATH=
# Optional explicit DNS ip hints for environments with unreliable DNS:
# e.g. indexer.dydx.trade:172.66.166.30,104.20.40.161
# QPA_INDEXER_HOST_IP_HINTS="indexer.dydx.trade:172.66.166.30,104.20.40.161"
# Optional fetch transport controls when DNS/proxying breaks Python requests:
# QPA_INDEXER_SCHEME=http|https       # Force indexer scheme
# QPA_DISABLE_SCHEME_FALLBACK=1       # Keep the requested scheme only
# QPA_USE_REQUESTS_FETCH=false        # Skip requests + use curl-first for indexer fetches

# Apify primary MCP data path
# Used for normal dYdX market/funding refreshes. Stage actor output into
# data/raw/dydx_inbox first, then promote approved payloads into data/raw/dydx_manual.
APIFY_API_TOKEN=your_apify_token_here
APIFY_MCP_SERVER_URL=https://mcp.apify.com/?tools=actors,docs,parseforge/dydx-v4-perpetual-markets-scraper,parseforge/dydx-markets-scraper,fraktalapi/funding-pulse,api_merge/coinglass-coin-markets,parseforge/hyperliquid-perp-funding-scraper,parseforge/gmx-arbitrum-stats-scraper,parseforge/gmx-arbitrum-prices-scraper,louisdeconinck/coinmarketcap-crypto-scraper,muhammetakkurtt/coinmarketcap-scraper,muhammetakkurtt/arkham-intelligence-wallet-data-scraper,real1ty/coingecko,gentle_cloud/cryptocurrency-market-data-scraper,moving_beacon-owner1/my-actor-14,muhammetakkurtt/dexscreener-scraper,muhammetakkurtt/dexscreener-realtime-monitor
APIFY_DYDX_MARKETS_ACTOR=parseforge/dydx-v4-perpetual-markets-scraper
APIFY_DYDX_FUNDING_ACTOR=fraktalapi/funding-pulse

# dYdX testnet paper trading
DYDX_TESTNET_WALLET_ADDRESS=
DYDX_TESTNET_PRIVATE_KEY=
# Optional overrides; defaults are in src/quant_platform/execution.py.
# DYDX_TESTNET_NODE_URL=oegs-testnet.dydx.exchange:443
# DYDX_TESTNET_REST_INDEXER=https://indexer.v4testnet.dydx.exchange
# DYDX_TESTNET_WEBSOCKET_INDEXER=wss://indexer.v4testnet.dydx.exchange/v4/ws
# DYDX_TESTNET_FAUCET_URL=https://faucet.v4testnet.dydx.exchange
# Keep false until research gates pass and an official dYdX client is wired.
DYDX_TESTNET_SUBMIT_ORDERS=false
